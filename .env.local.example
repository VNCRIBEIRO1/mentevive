# Variáveis de Ambiente — Psicolobia

# === Neon Database ===
DATABASE_URL=postgresql://user:password@ep-xxx.sa-east-1.aws.neon.tech/psicolobia?sslmode=require

# === NextAuth ===
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=gere-um-secret-com-openssl-rand-base64-32
# Compatibilidade Auth.js: pode usar AUTH_SECRET no lugar de NEXTAUTH_SECRET
# AUTH_SECRET=gere-um-secret-com-openssl-rand-base64-32
SETUP_SECRET=gere-outro-secret-exclusivo-para-bootstrap-inicial
TURNSTILE_SECRET_KEY=0x4AAAAA-seu-secret-aqui
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAA-seu-site-key-aqui

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Stripe (modo teste = sk_test_/pk_test_, produção = sk_live_/pk_live_) ===
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# === Seed Admin (opcional, usado apenas no db:seed) ===
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=defina-uma-senha-forte-com-12-ou-mais-caracteres
ADMIN_NAME=Administrador
