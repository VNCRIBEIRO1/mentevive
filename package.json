{
  "name": "mentevive",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.x <=24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:vercel": "node -e \"const fs=require('fs');['.\\.next','.\\.vercel/output'].forEach(d=>{try{fs.rmSync(d,{recursive:true})}catch{}})\" && npx vercel build --prod",
    "start": "next start",
    "lint": "eslint src/ --max-warnings 50",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:prepare-homolog": "npx tsx scripts/reset-and-seed-homolog.ts",
    "test": "vitest --maxWorkers=1",
    "test:run": "vitest run --maxWorkers=1"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "next-auth": "^4.24.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
